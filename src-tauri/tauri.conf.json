{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dispatch",
  "version": "0.1.0",
  "identifier": "ai.dispatch.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Dispatch",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
