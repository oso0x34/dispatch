# Optional runtime configuration.
#
# Dispatch reads these values from the process environment when it launches.
# Export them in your shell, direnv, or desktop launcher environment if needed.
# The app does not require a .env file for standalone mode.

# Optional OpenClaw gateway. Leave unset for standalone mode.
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# Optional OpenClaw auth token. Prefer Settings -> Secrets for local keychain storage.
OPENCLAW_GATEWAY_TOKEN=

# Optional provider credentials for local agent profiles.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
